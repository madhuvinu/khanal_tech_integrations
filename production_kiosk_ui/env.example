# Environment Configuration for Production Kiosk UI
# Copy this file to .env and update values for your environment

# Development API target (REQUIRED for npm run dev)
# Set this to your Frappe server URL and port
VITE_API_TARGET=http://localhost:8003

# Production base URL (optional - will use window.location.origin if not set)
VITE_BASE_URL=

# Frappe site name (optional - for multi-site setups)
VITE_SITE_NAME=
