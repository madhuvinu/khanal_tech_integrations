# Kiosk Frontend Environment Variables
# Copy this file to .env.local for local development

# =============================================================================
# API Configuration
# =============================================================================

# Base API URL (without trailing slash)
VITE_API_URL=http://localhost:8000

# WebSocket URL for real-time features
VITE_WS_URL=ws://localhost:8000

# =============================================================================
# Security
# =============================================================================

# Encryption key for localStorage data (32 characters recommended)
# Generate with: openssl rand -base64 32
VITE_ENCRYPTION_KEY=your-secret-encryption-key-here

# CSRF token name (should match backend)
VITE_CSRF_TOKEN_NAME=csrf_token

# =============================================================================
# Application Configuration
# =============================================================================

# Application base path (default: /kiosk)
VITE_BASE_PATH=/kiosk

# Environment mode
VITE_APP_ENV=development

# Enable debug mode
VITE_DEBUG=true

# Session timeout in minutes (default: 480 = 8 hours)
VITE_SESSION_TIMEOUT=480

# =============================================================================
# Feature Flags
# =============================================================================

# Enable PWA features
VITE_ENABLE_PWA=true

# Enable Sentry error tracking
VITE_ENABLE_SENTRY=false

# Sentry DSN
VITE_SENTRY_DSN=

# =============================================================================
# Plant Configuration
# =============================================================================

# Available plants (comma-separated)
VITE_AVAILABLE_PLANTS=krishnagiri,malur,mahadevpura,nandi_hills,champavath
